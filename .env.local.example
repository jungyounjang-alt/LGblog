# share.ps1 (그리고 호스팅 배포)에서 쓰는 토큰을 여기 채우세요.
# 이 파일을 .env.local로 복사한 뒤 값만 바꾸시면 됩니다 (.env.local은 git에 안 올라감).
#
# 새 토큰 생성:
#   node -e "console.log(require('crypto').randomBytes(16).toString('base64url'))"
#
# 처음 발급받은 값:
ADMIN_TOKEN=admin-여기에토큰입력
PARTNER_TOKEN=partner-여기에토큰입력

# (선택) localtunnel 서브도메인. 비워두면 lgblog-yj 시도.
# SHARE_SUBDOMAIN=lgblog-yj
