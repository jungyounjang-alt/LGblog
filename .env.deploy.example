# Environment variables to set in Railway → Variables tab.
# Generate fresh values with:  node -e "console.log(require('crypto').randomBytes(16).toString('base64url'))"

# Required in production
NODE_ENV=production
ADMIN_TOKEN=<paste your secret here>
PARTNER_TOKEN=<paste your secret here>

# Auto-injected by Railway when you link the Postgres service
# DATABASE_URL=${{Postgres.DATABASE_URL}}
